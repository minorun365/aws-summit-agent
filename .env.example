# AWS region for Bedrock, AgentCore, and Amplify sandbox.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Optional model overrides.
MODEL_ID=us.anthropic.claude-sonnet-4-6
HTTP_SUMMARY_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional: use an existing Bedrock Knowledge Base instead of the generated one.
SUMMIT_KB_ID=

# Optional: Tavily API key secret. Store the API key in AWS Secrets Manager.
# Example secret JSON: {"apiKey":"YOUR_TAVILY_API_KEY"}
TAVILY_API_SECRET_ARN=
